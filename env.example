# =============================================================================
# Collibra DQ Starter — Environment Variables Reference
#
# Copy this file and source it before running dqctl:
#   cp env.example .env.dev
#   # Edit .env.dev with your values
#   source .env.dev
#   dqctl --env dev --region eu-west-1 deploy --target full
#
# Required variables are marked with [REQUIRED].
# Blank defaults mean the value is auto-resolved or optional.
# =============================================================================

# ---------------------------------------------------------------------------
# Core (required for all operations)
# ---------------------------------------------------------------------------
export TF_VAR_environment=dev                # [REQUIRED] dev | prod
export TF_VAR_region=eu-west-1               # [REQUIRED] Any valid AWS region
export COLLIBRA_DQ_LICENSE_KEY=              # [REQUIRED for addon/full deploy] UUID from Collibra

# ---------------------------------------------------------------------------
# Organization & Naming
# ---------------------------------------------------------------------------
# export TG_ORG=dq                           # Prefix for all resource names
# export TG_PROJECT=Collibra-DQ-Starter      # Project tag value
# export TG_COST_CENTER=Engineering           # CostCenter tag value

# ---------------------------------------------------------------------------
# VPC Configuration (defaults are env-aware: dev vs prod)
# ---------------------------------------------------------------------------
# export TG_COLLIBRA_DQ_VPC_CIDR=            # VPC CIDR (default: 10.11.0.0/16 dev, 10.21.0.0/16 prod)
# export TG_VPC_AZ_COUNT=                    # Number of AZs: 2-3 (default: 2 dev, 3 prod)
# export TG_SINGLE_NAT_GATEWAY=              # Single NAT gateway (default: true dev, false prod)
# export TG_ENABLE_FLOW_LOG=                 # VPC flow logs (default: false dev, true prod)

# ---------------------------------------------------------------------------
# RDS Configuration
# ---------------------------------------------------------------------------
# export TG_RDS_INSTANCE_CLASS=              # default: db.t3.medium dev, db.t3.small prod
# export TG_RDS_ALLOCATED_STORAGE=100        # Initial storage in GB
# export TG_RDS_MAX_ALLOCATED_STORAGE=       # Max autoscale storage (default: 200 dev, 500 prod)
# export TG_RDS_DELETION_PROTECTION=         # default: false dev, true prod
# export TG_RDS_MULTI_AZ=                    # default: false dev, true prod
# export TG_RDS_BACKUP_RETENTION=            # Backup retention days (default: 7 dev, 14 prod)

# ---------------------------------------------------------------------------
# Collibra DQ EC2 Instance
# ---------------------------------------------------------------------------
# export TG_COLLIBRA_DQ_INSTANCE_TYPE=       # default: m5.large dev, m5.xlarge prod
# export TG_COLLIBRA_DQ_VOLUME_SIZE=         # Root EBS volume in GB (default: 100 dev, 200 prod)
# export TG_COLLIBRA_DQ_PUBLIC_SUBNET=       # Place EC2 in public subnet (default: true in dev, always false in prod). Saves ~$55/mo by skipping NAT Gateway + VPC interface endpoints.
# export COLLIBRA_DQ_AMI_ID=                 # AMI override (auto-resolved to latest RHEL 7.9 if unset)
# export COLLIBRA_DQ_OWL_BASE=/opt/collibra-dq
# export COLLIBRA_DQ_SPARK_PACKAGE=spark-3.5.6-bin-hadoop3.tgz
# export COLLIBRA_DQ_ADMIN_PASSWORD=         # DQ Web UI admin password. 8-72 chars, uppercase + digit + special (!%&@#$^?_~), no 'admin'. Auto-generated if unset/invalid.

# ---------------------------------------------------------------------------
# ALB Configuration
# ---------------------------------------------------------------------------
# export TG_ALB_DELETION_PROTECTION=         # default: false dev, true prod

# ---------------------------------------------------------------------------
# Package & Artifact
# ---------------------------------------------------------------------------
# export COLLIBRA_DQ_PACKAGE_FILENAME=dq-2025.11-SPARK356-JDK17-package-full.tar
# export COLLIBRA_DQ_PACKAGE_URL=            # S3/HTTP URL (auto-derived from artifact bucket if unset)
# export COLLIBRA_DQ_PACKAGE_URL_OVERRIDE=   # Override package URL directly in Terragrunt inputs
# export COLLIBRA_DQ_PACKAGE_LOCAL_PATH=     # Local file path for package upload
# export COLLIBRA_DQ_SKIP_PACKAGE_UPLOAD=false
# export COLLIBRA_DQ_ENABLE_S3_ACCELERATION=false

# ---------------------------------------------------------------------------
# License
# ---------------------------------------------------------------------------
# export COLLIBRA_DQ_LICENSE_NAME=collibra-partners
# export COLLIBRA_DQ_INSTALLATION_ID=        # Installation UUID (optional)

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# export COLLIBRA_DQ_ENABLE_STANDALONE_HOOK=false   # after_hook for target attachment on standalone apply
# export COLLIBRA_DQ_ENABLE_ROTATION_RESTART=true   # EventBridge rule for RDS secret rotation restart
# export COLLIBRA_DQ_ENABLE_ROTATION_ALARMS=true    # CloudWatch alarms for rotation failures

# ---------------------------------------------------------------------------
# SSM Parameter Store (avoids embedding secrets in Terraform state)
# ---------------------------------------------------------------------------
# export COLLIBRA_DQ_RDS_PASSWORD_SSM_PARAMETER=
# export COLLIBRA_DQ_ADMIN_PASSWORD_SSM_PARAMETER=
# export COLLIBRA_DQ_LICENSE_KEY_SSM_PARAMETER=
# export COLLIBRA_DQ_LICENSE_NAME_SSM_PARAMETER=

# ---------------------------------------------------------------------------
# Alarm Actions (SNS topic ARNs)
# ---------------------------------------------------------------------------
# export COLLIBRA_DQ_ROTATION_ALARM_ACTIONS=
# export COLLIBRA_DQ_ROTATION_OK_ACTIONS=
